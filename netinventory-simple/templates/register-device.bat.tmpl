@echo off
setlocal EnableDelayedExpansion
set TARGET_URL=%TRACK_SIMPLE_URL%
if "%TARGET_URL%"=="" set TARGET_URL=__TARGET_URL__
set TOKEN=%TRACK_SIMPLE_TOKEN%
if "%TOKEN%"=="" set TOKEN=__TOKEN__
set DESCRIPTION=%1
if "%DESCRIPTION%"=="" set DESCRIPTION=%COMPUTERNAME%

powershell -NoProfile -ExecutionPolicy Bypass -Command ^
  "$payload = @{ kind='script-batch'; description=$env:DESCRIPTION; hostname=$env:COMPUTERNAME; user=$env:USERNAME; os=[System.Environment]::OSVersion.VersionString; ips=((Get-NetIPConfiguration | Select-Object -ExpandProperty IPv4Address | Select-Object -ExpandProperty IPAddress) -join ', '); } | ConvertTo-Json -Compress; " ^
  "Invoke-RestMethod -Method Post -Uri $env:TARGET_URL -Headers @{ 'X-NetInventory-Simple-Token' = $env:TOKEN } -ContentType 'application/json' -Body $payload | Out-Null"

echo NetInventory simple upload complete.
