# Local backend configuration for experimental model reconstruction.
# Copy to: map3d/model-backends.env

# HY-World / WorldMirror 2.0
HYWORLD_REPO=/absolute/path/to/HY-World-2.0
HYWORLD_PYTHON=/absolute/path/to/HY-World-2.0/.venv/bin/python
HYWORLD_USE_CAMERA_PRIOR=1
HYWORLD_NPROC_PER_NODE=2

# Lyra placeholder
LYRA_REPO=/absolute/path/to/lyra
LYRA_PYTHON=/absolute/path/to/lyra/.venv/bin/python
