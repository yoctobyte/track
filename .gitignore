# 1. Ignore everything by default
*

# 2. Unignore all directories so we can traverse them
!*/

# 3. Re-ignore specific directories we don't want traversed at all
__pycache__/
venv/
.git/

# 4. Allowlist explicit files
!.gitignore
!README.md
!requirements.txt
!run.py
!run.sh
!config.py
!config.json

# App source and assets
!app/__init__.py
!app/templates/*.html
!app/static/css/*.css
!app/data/translations.json
